{
  "name": "ai-interview-desktop",
  "version": "1.0.0",
  "description": "AI Interview Platform — Desktop Application",
  "main": "main.js",
  "author": "AI Interview Platform",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.interview.ai-platform",
    "productName": "AI Interview Platform",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "web/**/*"
    ],
    "forceCodeSigning": false,
    "win": {
      "target": ["nsis"],
      "icon": null,
      "signAndEditExecutable": false,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.education"
    },
    "linux": {
      "target": ["AppImage"]
    }
  }
}
